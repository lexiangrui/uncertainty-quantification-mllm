# Semantic Uncertainty – environment configuration
# Copy this file to sem_unc.env and edit paths for your cluster.
#
# Usage:
#   source configs/sem_unc.env
#   python scripts/run_semantic_uncertainty.py --dataset cvbench

# --- Asset roots ---
SEM_UNC_ASSETS_DIR=/opt/lexiangrui/sem_unc_assets
SEM_UNC_MODELS_DIR=${SEM_UNC_ASSETS_DIR}/models
SEM_UNC_DATASETS_DIR=${SEM_UNC_ASSETS_DIR}/datasets

# --- Model paths ---
# Direct path to a specific model (overrides SEM_UNC_MODELS_DIR).
# SEM_UNC_MODEL_PATH=${SEM_UNC_MODELS_DIR}/llava-1.5-7b-hf

# --- Hugging Face offline mode (for cluster compute nodes) ---
# HF_HUB_OFFLINE=1
# HF_DATASETS_OFFLINE=1
# TRANSFORMERS_OFFLINE=1
# HF_ENDPOINT=https://hf-mirror.com  # Use mirror for mg01 downloads
# HF_HOME=${SEM_UNC_ASSETS_DIR}/hf_cache

# --- ViLP parquet (shared with vauq-repro) ---
# VILP_PARQUET_PATH=${SEM_UNC_DATASETS_DIR}/vilp/ViLP.parquet

# --- Text model paths ---
# LLAMA2_7B_CHAT_HF_MODEL=${SEM_UNC_MODELS_DIR}/Llama-2-7b-chat-hf
# DEBERTA_MNLI_MODEL=${SEM_UNC_MODELS_DIR}/deberta-v2-xlarge-mnli

# --- vauq-repro fallback (if sharing the same asset directories) ---
# VAUQ_MODELS_DIR=${SEM_UNC_MODELS_DIR}
# VAUQ_DATASETS_DIR=${SEM_UNC_DATASETS_DIR}
