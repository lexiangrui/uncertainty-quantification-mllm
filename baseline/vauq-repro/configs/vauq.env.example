# VAUQ 复现工程统一配置（所有模型/数据集路径与共享环境变量放这一份）。
# 复制为 vauq.env 后按集群实际情况修改。.gitignore 已忽略 configs/*.env。

# ---- 统一资产根目录：模型与数据集都集中在这一个目录下 ----
export VAUQ_ASSETS_DIR="/opt/lexiangrui/vauq_assets"
export VAUQ_MODELS_DIR="${VAUQ_ASSETS_DIR}/models"
export VAUQ_DATASETS_DIR="${VAUQ_ASSETS_DIR}/datasets"

# ---- 推理模型路径（本地目录或 HF repo id；默认放在 VAUQ_MODELS_DIR 下）----
export LLAVA_7B_HF_MODEL="${VAUQ_MODELS_DIR}/llava-1.5-7b-hf"
export LLAVA_13B_HF_MODEL="${VAUQ_MODELS_DIR}/llava-1.5-13b-hf"
export QWEN_JUDGE_MODEL="${VAUQ_MODELS_DIR}/Qwen2.5-3B-Instruct"

# Backward-compatible alias used by older LLaVA smoke scripts.
export LLAVA_HF_MODEL="${LLAVA_7B_HF_MODEL}"

# ---- Python 解释器（venv）----
export PYTHON_BIN="/home/lexiangrui/.venvs/vlm-transformers/bin/python3"

# ---- Hugging Face 缓存与镜像 ----
# 模型 hub 缓存（按 repo id 加载时用；本工程模型走 local-dir，此项主要是兜底）。
export HF_HOME="/opt/lexiangrui/hf_cache"
export HF_HUB_CACHE="/opt/lexiangrui/hf_cache/hub"
export TRANSFORMERS_CACHE="/opt/lexiangrui/hf_cache/hub"
export HF_MODULES_CACHE="/opt/lexiangrui/hf_cache/modules"
# 数据集统一目录：所有数据集集中下到这里（VAUQ_DATASETS_DIR）。
export HF_DATASETS_CACHE="${VAUQ_DATASETS_DIR}"
export VILP_PARQUET_PATH="${VAUQ_DATASETS_DIR}/vilp/ViLP.parquet"
export HF_ENDPOINT="https://hf-mirror.com"

# ---- Optional API judge（复制到私有 env 文件中填 key；不要提交真实 key）----
export LLM_JUDGE_BASE_URL="https://api.cdn-krill-ai.com/coding/v1"
export LLM_JUDGE_MODEL="deepseek-v4-flash:free"
# export LLM_JUDGE_API_KEY="..."
