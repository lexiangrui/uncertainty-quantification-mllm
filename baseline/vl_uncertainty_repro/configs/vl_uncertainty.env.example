# Copy to configs/vl_uncertainty.env and edit local paths for cluster runs.

export VLU_ASSETS_DIR=/opt/lexiangrui/vlu_assets
export VLU_MODEL_PATH=$VLU_ASSETS_DIR/models/llava-1.5-7b-hf
export VLU_TEXT_MODEL_PATH=$VLU_ASSETS_DIR/models/Qwen2.5-3B-Instruct

# Optional Hugging Face cache/offline knobs.
export HF_HOME=$VLU_ASSETS_DIR/hf_home
export HF_DATASETS_CACHE=$VLU_ASSETS_DIR/datasets
export TRANSFORMERS_CACHE=$VLU_ASSETS_DIR/models

# Cluster venv, if available.
export PYTHON_BIN=/home/lexiangrui/.venvs/vlm-transformers/bin/python
